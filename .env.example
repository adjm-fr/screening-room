# Shared workspace .env — copy to `.env` at the repo root: `cp .env.example .env`
#
# Every member (movies_management, cinema_dashboard) reads this single file.
# Each member ignores keys it doesn't declare (extra="ignore"), so the union of
# all vars lives here without collisions. Vars consumed by more than one member
# are noted inline.

# ── shared by movies_management + cinema_dashboard ───────────────────────────
# Output directory: movies_management writes its parquets here
# (data_letterboxd.parquet, ratings_with_letterboxd.parquet,
#  watchlist_with_letterboxd.parquet) and cinema_dashboard reads them from here.
OUTPUT_PATH=/your/output/path

# Number of days before a cached movie entry is considered stale.
LETTERBOXD_DAYS_TO_UPDATE=365
# TMDB API key (v3) — French title enrichment (movies_management) and the FR
# streaming-availability cache (cinema_dashboard). Create one free at
# https://www.themoviedb.org/settings/api  (leave unset to skip enrichment)
TMDB_API_KEY=

# ── movies_management ────────────────────────────────────────────────────────
# LETTERBOXD_USERNAME is a CLI argument: python main.py --username <your_username>
# Max stale movies to refresh per run (default 1000; raise to lift the cap).
LETTERBOXD_REFRESH_LIMIT=1000

# ── cinema_dashboard ─────────────────────────────────────────────────────────
# Allocine scraper paths (mirrors Allocine-Showtimes-Scraping/.env)
ALLOCINE_INPUT_PATH=/path/to/data_cinema/theaters/theaters.csv
ALLOCINE_OUTPUT_PATH=/path/to/data_cinema/theaters/showtimes.parquet

# Letterboxd username for cinema_dashboard pages
LETTERBOXD_USERNAME=your_username

# Gemini model and token limit for the Recommendations page (optional — defaults shown)
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.8

# Gemini API key for the Recommendations page
# Create one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Streaming services you personally subscribe to (comma-separated slugs:
# lowercase, no spaces/symbols — "Canal+" -> canalplus). Declared now;
# consumed by the Phase 3 UI to flag "you already subscribe to this".
STREAMING_SERVICES=mubi,netflix,canalplus

# Logging verbosity for app.py and orchestrate.py (optional — default INFO).
# Set to DEBUG to trace the render/join hot paths during development.
LOG_LEVEL=INFO
