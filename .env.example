# Hugging Face API key for the Recommendations page
HF_API_KEY=your_hf_api_key_here

# Path to movies_management output directory
# (where data_letterboxd.parquet, ratings_with_letterboxd.parquet,
#  and watchlist_with_letterboxd.parquet are stored)
MOVIES_OUTPUT_PATH=/path/to/data_cinema/movies

# Allocine scraper paths (mirrors Allocine-Showtimes-Scraping/.env)
ALLOCINE_INPUT_PATH=/path/to/data_cinema/theaters/theaters.csv
ALLOCINE_OUTPUT_PATH=/path/to/data_cinema/theaters/showtimes.parquet

# Letterboxd username (mirrors movies_management/.env)
LETTERBOXD_USERNAME=your_username

# Number of days before a cached movie entry is considered stale.
# Must match the value set in movies_management/.env (default: 365).
LETTERBOXD_DAYS_TO_UPDATE=365
