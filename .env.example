# LETTERBOXD_USERNAME is now a CLI argument: python main.py --username <your_username>

OUTPUT_PATH=/your/output/path
LETTERBOXD_DAYS_TO_UPDATE=365
# Max stale movies to refresh per run (leave unset for no limit)
LETTERBOXD_REFRESH_LIMIT=
# Optional: TMDB API key for French title enrichment (leave unset to skip)
TMDB_API_KEY=
